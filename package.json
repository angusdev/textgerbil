{
  "name": "textgerbil",
  "version": "1.0.0",
  "description": "Single-file browser text editor with multi-tab modes and headless tests.",
  "main": "index.html",
  "scripts": {
    "test:unit": "node test/run_unit_tests.js",
    "test:headless": "node test/run_headless_test.js",
    "test": "npm run test:unit && npm run test:headless",
    "lint": "eslint index.html",
    "lint:fix": "eslint index.html --fix"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "jsdom": "21.1.2"
  },
  "keywords": [
    "text-editor",
    "codemirror",
    "markdown",
    "quill",
    "vanilla-js"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-html": "^8.1.4"
  }
}